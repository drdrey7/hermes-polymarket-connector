# .env.example — copy to .env and fill in (NEVER commit .env)
# Required for live trading
# Private key (64 hex chars, 0x prefix) - NEVER SHARE THIS
POLYMARKET_PRIVATE_KEY=0x...your-private-key...
# Funder address (deposit wallet address on Polymarket, 40 hex chars)
POLYMARKET_FUNDER_ADDRESS=0x...your-deposit-wallet-address...
# Signature type (3 = new API users / deposit wallet flow, 1 = legacy)
POLYMARKET_SIGNATURE_TYPE=3
# Optional: proxy wallet address
# POLYMARKET_PROXY_WALLET=0x...proxy-address...

# RPC / API (defaults shown)
POLYMARKET_RPC_URL=https://polygon-rpc.com
POLYMARKET_CLOB_API_URL=https://clob.polymarket.com
POLYMARKET_CHAIN_ID=137

# Live trading gates — ALL must be true for real execution
LIVE_TRADING=false
REQUIRE_CONFIRMATION=true

# Risk limits — TINY defaults for first live test
MAX_ORDER_USD=1
MAX_DAILY_USD=3
MAX_POSITION_USD=5
MAX_SLIPPAGE_BPS=100
MAX_OPEN_ORDERS=50

# Geoblock — uses official Polymarket endpoint at runtime
GEOBLOCK_CHECK=true

# Audit
AUDIT_LOG_PATH=~/.hermes/polymarket-action/audit.log